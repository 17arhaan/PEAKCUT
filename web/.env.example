# Copy to .env.local for local dev. See web/SETUP.md for the full walkthrough.

# --- Required in dev (validated by lib/env.ts, boot fails loudly if missing) ---

# Postgres connection string. Start the local db: docker compose up -d db (arrives in Task 2).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/shorts_factory"

# Auth.js session secret. Generate: openssl rand -base64 32
AUTH_SECRET="changeme"

# NEVER set AUTH_DEV=1 outside local development — enables passwordless login.
# Enables the dev credentials sign-in provider (any email works, no real auth). Task 3+.
AUTH_DEV="1"

# --- Optional, gated behind features that arrive in later tasks ---
# Leave unset locally; each is only read once its seam/feature is wired up.

# Storage seam: LocalStorage -> R2Storage swap-in.
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
# R2_ACCOUNT_ID=

# Worker seam: LocalWorker -> ModalWorker swap-in.
# MODAL_TOKEN_ID=
# MODAL_TOKEN_SECRET=

# Google OAuth sign-in, alongside the always-on dev provider.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Merchant-of-record billing (Dodo Payments preferred, Paddle fallback).
# DODO_API_KEY=
# DODO_WEBHOOK_SECRET=
